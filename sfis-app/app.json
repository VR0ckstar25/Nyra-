{
  "expo": {
    "name": "Nyara",
    "slug": "nyara",
    "scheme": "nyara",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": [
      "ios",
      "android"
    ],
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#FCEDF3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nyara.app",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.nyara.app",
      "adaptiveIcon": {
        "backgroundColor": "#FCEDF3"
      },
      "permissions": [
        "CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Nyara to use the camera to read ingredient labels."
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-build-properties"
    ]
  }
}
