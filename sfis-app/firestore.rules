rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // If the payload carries an ownerUid, it must match the authenticated user —
    // blocks a buggy/compromised client writing another person's records into
    // its own tree (defense for the cross-account guard on the client).
    function payloadOwnerOk() {
      return !('ownerUid' in request.resource.data)
        || request.resource.data.ownerUid == request.auth.uid;
    }

    match /users/{uid} {
      allow read, write: if owns(uid);

      match /profile/{docId} {
        allow read, delete: if owns(uid);
        allow create, update: if owns(uid) && payloadOwnerOk();
      }

      match /scans/{scanId} {
        allow read, delete: if owns(uid);
        allow create, update: if owns(uid) && payloadOwnerOk();
      }

      match /feedback/{feedbackId} {
        allow read, delete: if owns(uid);
        allow create, update: if owns(uid) && payloadOwnerOk();
      }

      // Audit trail: append-only (no edits), but the OWNER may DELETE — the right to
      // erasure (GDPR/CCPA) overrides append-only; retaining data after a delete
      // request is itself a violation. Updates stay forbidden so history isn't rewritten.
      match /events/{eventId} {
        allow read: if owns(uid);
        allow create: if owns(uid) && payloadOwnerOk();
        allow update: if false;
        allow delete: if owns(uid);
      }

      match /meta/{docId} {
        allow read, write: if owns(uid);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
